@model LoginViewModel
@using System.Globalization
@{
    ViewData["Title"] = Html.T("Login.SignInBtn");
    Layout = null;
    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var basePath = Context.Request.Path;
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Html.T("Login.SignInBtn") — @Html.T("App.Title")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            min-height: 100vh;
            margin: 0;
            font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #0f172a 100%);
            display: flex; align-items: flex-start; justify-content: center;
            padding: 40px 20px;
            color: #1f2937;
        }
        .page-shell {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 28px;
            width: 100%;
            max-width: 980px;
        }
        .login-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            max-width: 980px; width: 100%;
            background: #fff;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,.35), 0 0 0 1px rgba(255,255,255,.05);
        }
        .team-panel {
            width: 100%;
            background: rgba(255,255,255,.06);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 18px;
            padding: 28px 32px;
            color: #e5e7eb;
        }
        .team-header {
            display: flex; align-items: center; justify-content: space-between;
            gap: 12px; margin-bottom: 20px; flex-wrap: wrap;
        }
        .team-title {
            display: inline-flex; align-items: center; gap: 10px;
            font-size: 16px; font-weight: 700; color: #fff; letter-spacing: .01em;
        }
        .team-title .badge-icon {
            width: 30px; height: 30px; border-radius: 8px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 15px;
            box-shadow: 0 6px 14px rgba(37,99,235,.45);
        }
        .team-meta { font-size: 12px; color: rgba(255,255,255,.55); }
        .team-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }
        .member-card {
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 14px;
            padding: 18px 16px;
            transition: transform .15s, border-color .15s, background .15s;
            position: relative;
            overflow: hidden;
        }
        .member-card:hover {
            transform: translateY(-2px);
            border-color: rgba(96,165,250,.45);
            background: rgba(255,255,255,.07);
        }
        .member-card.lead {
            background: linear-gradient(160deg, rgba(37,99,235,.22), rgba(15,23,42,.25));
            border-color: rgba(96,165,250,.4);
        }
        .member-head {
            display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
        }
        .avatar {
            width: 38px; height: 38px; border-radius: 50%;
            background: linear-gradient(135deg, #60a5fa, #2563eb);
            color: #fff; font-weight: 700; font-size: 14px;
            display: inline-flex; align-items: center; justify-content: center;
            border: 2px solid rgba(255,255,255,.2);
            flex-shrink: 0;
        }
        .member-card.lead .avatar {
            background: linear-gradient(135deg, #fbbf24, #d97706);
            border-color: rgba(251,191,36,.45);
            box-shadow: 0 0 0 4px rgba(251,191,36,.12);
        }
        .member-name { font-size: 14px; font-weight: 600; color: #fff; line-height: 1.25; }
        .member-stt { font-size: 11px; color: rgba(255,255,255,.55); margin-top: 2px; }
        .role-tag {
            display: inline-block;
            font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
            padding: 3px 8px; border-radius: 999px;
            background: rgba(96,165,250,.18); color: #bfdbfe;
            margin-bottom: 10px;
        }
        .member-card.lead .role-tag {
            background: rgba(251,191,36,.18); color: #fde68a;
        }
        .task-list { list-style: none; padding: 0; margin: 0; }
        .task-list li {
            font-size: 12px; color: rgba(255,255,255,.78);
            padding: 4px 0 4px 16px; position: relative; line-height: 1.4;
        }
        .task-list li::before {
            content: '▸'; position: absolute; left: 0; top: 4px;
            color: #60a5fa; font-size: 11px;
        }
        .member-card.lead .task-list li::before { color: #fbbf24; }
        .supervisor-card {
            display: flex; align-items: center; gap: 16px;
            padding: 16px 18px;
            margin-bottom: 18px;
            background: linear-gradient(110deg, rgba(124,58,237,.22), rgba(37,99,235,.18));
            border: 1px solid rgba(167,139,250,.35);
            border-radius: 14px;
            box-shadow: 0 6px 18px rgba(76,29,149,.18);
        }
        .supervisor-icon {
            width: 46px; height: 46px; border-radius: 12px; flex-shrink: 0;
            background: linear-gradient(135deg, #a78bfa, #6d28d9);
            color: #fff; font-size: 22px;
            display: inline-flex; align-items: center; justify-content: center;
            border: 1px solid rgba(255,255,255,.25);
            box-shadow: 0 6px 14px rgba(109,40,217,.4);
        }
        .supervisor-meta { display: flex; flex-direction: column; min-width: 0; }
        .supervisor-label {
            font-size: 11px; font-weight: 700; letter-spacing: .08em;
            text-transform: uppercase; color: #c4b5fd; margin-bottom: 2px;
        }
        .supervisor-name { font-size: 16px; font-weight: 700; color: #fff; line-height: 1.25; }
        .supervisor-institution { font-size: 12.5px; color: rgba(255,255,255,.7); margin-top: 2px; }
        @@media (max-width: 768px) {
            .team-grid { grid-template-columns: 1fr; }
            .team-panel { padding: 22px 20px; }
            .supervisor-card { flex-direction: column; align-items: flex-start; text-align: left; }
        }
        .brand-panel {
            background: linear-gradient(160deg, #1e40af 0%, #0c1f4e 100%);
            color: #fff;
            padding: 48px 40px;
            position: relative;
            overflow: hidden;
        }
        .brand-panel::before {
            content: ''; position: absolute; top: -80px; right: -80px;
            width: 280px; height: 280px;
            background: radial-gradient(circle, rgba(59,130,246,.45), transparent 70%);
            border-radius: 50%;
        }
        .brand-panel::after {
            content: ''; position: absolute; bottom: -100px; left: -100px;
            width: 320px; height: 320px;
            background: radial-gradient(circle, rgba(96,165,250,.25), transparent 70%);
            border-radius: 50%;
        }
        .brand-panel > * { position: relative; z-index: 1; }
        .brand-logo { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 22px; margin-bottom: 48px; }
        .logo-mark {
            width: 36px; height: 36px;
            background: rgba(255,255,255,.15);
            border-radius: 9px;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 18px;
            border: 1px solid rgba(255,255,255,.18);
        }
        .brand-headline { font-size: 30px; font-weight: 700; line-height: 1.2; margin-bottom: 14px; letter-spacing: -.02em; }
        .brand-sub { color: rgba(255,255,255,.7); margin-bottom: 36px; font-size: 15px; line-height: 1.55; }
        .feature { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 18px; color: rgba(255,255,255,.85); font-size: 14px; }
        .feature .dot { width: 8px; height: 8px; border-radius: 50%; background: #60a5fa; margin-top: 6px; flex-shrink: 0; box-shadow: 0 0 0 4px rgba(96,165,250,.18); }
        .lang-toggle {
            position: absolute; top: 20px; right: 20px; z-index: 2;
            background: rgba(255,255,255,.12); color: #fff;
            padding: 6px 12px; border-radius: 999px;
            font-size: 12px; border: 1px solid rgba(255,255,255,.2);
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .lang-toggle a { color: rgba(255,255,255,.7); padding: 0 4px; }
        .lang-toggle a.active-lang { color: #fff; font-weight: 600; }
        .lang-toggle a:hover { color: #fff; }
        .form-panel { padding: 56px 48px; display: flex; flex-direction: column; justify-content: center; }
        .form-panel h2 { font-weight: 700; font-size: 28px; margin-bottom: 6px; color: #111827; letter-spacing: -.02em; }
        .form-panel .lead { color: #6b7280; font-size: 14px; margin-bottom: 32px; }
        .form-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .03em; }
        .form-control { padding: 12px 14px; border-radius: 10px; border: 1px solid #e5e7eb; font-size: 15px; transition: all .15s; background: #f9fafb; }
        .form-control:focus { border-color: #2563eb; box-shadow: 0 0 0 4px rgba(37,99,235,.12); background: #fff; }
        .btn-primary {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            border: none; padding: 13px; font-weight: 600; border-radius: 10px; font-size: 15px;
            box-shadow: 0 8px 20px rgba(37,99,235,.3);
            transition: transform .12s, box-shadow .12s;
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 10px 28px rgba(37,99,235,.4); background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 100%); }
        @@media (max-width: 768px) {
            .login-wrapper { grid-template-columns: 1fr; max-width: 440px; }
            .brand-panel { display: none; }
            .form-panel { padding: 40px 28px; }
        }
    </style>
</head>
<body>
    <div class="page-shell">
    <div class="login-wrapper">
        <div class="brand-panel">
            <div class="lang-toggle">
                🌐
                <a class="@(currentCulture == "en" ? "active-lang" : "")" href="@basePath?culture=en">EN</a>|
                <a class="@(currentCulture == "vi" ? "active-lang" : "")" href="@basePath">VI</a>
            </div>
            <div class="brand-logo">
                <span class="logo-mark">⚙</span>
                @Html.T("App.Brand")
            </div>
            <h1 class="brand-headline">@Html.Raw(Html.T("Login.Headline"))</h1>
            <p class="brand-sub">@Html.T("Login.Sub")</p>

            <div class="feature"><span class="dot"></span><span>@Html.T("Login.Feature1")</span></div>
            <div class="feature"><span class="dot"></span><span>@Html.T("Login.Feature2")</span></div>
            <div class="feature"><span class="dot"></span><span>@Html.T("Login.Feature3")</span></div>
            <div class="feature"><span class="dot"></span><span>@Html.T("Login.Feature4")</span></div>
        </div>

        <div class="form-panel">
            <h2>@Html.T("Login.Welcome")</h2>
            <p class="lead">@Html.T("Login.Subtitle")</p>

            <form asp-action="Login" method="post" novalidate>
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">@Html.T("Login.Username")</label>
                    <input asp-for="Username" class="form-control" autocomplete="username" autofocus placeholder="@Html.T("Login.UsernamePlaceholder")" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">@Html.T("Login.Password")</label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="@Html.T("Login.PasswordPlaceholder")" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label small text-muted">@Html.T("Login.RememberMe")</label>
                </div>

                <button type="submit" class="btn btn-primary w-100">@Html.T("Login.SignInBtn") →</button>
            </form>
        </div>
    </div>

    <section class="team-panel" aria-labelledby="team-title">
        <div class="team-header">
            <div class="team-title" id="team-title">
                <span class="badge-icon">👥</span>
                @Html.T("Team.Title")
            </div>
            <span class="team-meta">@Html.T("Team.Meta")</span>
        </div>

        <div class="supervisor-card" role="group" aria-labelledby="supervisor-label">
            <span class="supervisor-icon" aria-hidden="true">🎓</span>
            <div class="supervisor-meta">
                <span class="supervisor-label" id="supervisor-label">@Html.T("Team.SupervisorLabel")</span>
                <span class="supervisor-name">@Html.T("Team.SupervisorName")</span>
                <span class="supervisor-institution">@Html.T("Team.SupervisorInstitution")</span>
            </div>
        </div>

        <div class="team-grid">
            <article class="member-card">
                <div class="member-head">
                    <div class="avatar">NP</div>
                    <div>
                        <div class="member-name">@Html.T("Team.Phuong.Name")</div>
                        <div class="member-stt">@Html.T("Team.SttLabel") 20</div>
                    </div>
                </div>
                <span class="role-tag">@Html.T("Team.Role.Research")</span>
                <ul class="task-list">
                    <li>@Html.T("Team.Phuong.Task1")</li>
                    <li>@Html.T("Team.Phuong.Task2")</li>
                    <li>@Html.T("Team.Phuong.Task3")</li>
                    <li>@Html.T("Team.Phuong.Task4")</li>
                </ul>
            </article>

            <article class="member-card">
                <div class="member-head">
                    <div class="avatar">NL</div>
                    <div>
                        <div class="member-name">@Html.T("Team.Ly.Name")</div>
                        <div class="member-stt">@Html.T("Team.SttLabel") 39</div>
                    </div>
                </div>
                <span class="role-tag">@Html.T("Team.Role.Design")</span>
                <ul class="task-list">
                    <li>@Html.T("Team.Ly.Task1")</li>
                    <li>@Html.T("Team.Ly.Task2")</li>
                    <li>@Html.T("Team.Ly.Task3")</li>
                    <li>@Html.T("Team.Ly.Task4")</li>
                </ul>
            </article>

            <article class="member-card lead">
                <div class="member-head">
                    <div class="avatar">NH</div>
                    <div>
                        <div class="member-name">@Html.T("Team.Huyen.Name")</div>
                        <div class="member-stt">@Html.T("Team.SttLabel") 51 · @Html.T("Team.LeadSuffix")</div>
                    </div>
                </div>
                <span class="role-tag">@Html.T("Team.Role.Lead")</span>
                <ul class="task-list">
                    <li>@Html.T("Team.Huyen.Task1")</li>
                    <li>@Html.T("Team.Huyen.Task2")</li>
                    <li>@Html.T("Team.Huyen.Task3")</li>
                    <li>@Html.T("Team.Huyen.Task4")</li>
                </ul>
            </article>
        </div>
    </section>
    </div>
    <script>
        (function () {
            try {
                var url = new URL(window.location.href);
                if (url.searchParams.has('culture')) {
                    url.searchParams.delete('culture');
                    window.history.replaceState({}, '', url.pathname + (url.search || '') + url.hash);
                }
            } catch (e) { /* old browser, ignore */ }
        })();
    </script>
</body>
</html>
