@model RegisterUserViewModel
@{ ViewData["Title"] = Html.T("Users.CreateTitle"); }
<div class="page-header">
    <div><h2>@Html.T("Users.CreateTitle")</h2><div class="subtitle">@Html.T("Users.CreateSub")</div></div>
    <a class="btn btn-outline-secondary" asp-controller="Users" asp-action="Index">← @Html.T("Common.Back")</a>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="Register" method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small col-12 mb-0"></div>
            <div class="col-md-6"><label asp-for="Username" class="form-label">@Html.T("Users.Username")</label><input asp-for="Username" class="form-control" /><span asp-validation-for="Username" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="Email" class="form-label">@Html.T("Users.Email")</label><input asp-for="Email" class="form-control" /><span asp-validation-for="Email" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="FullName" class="form-label">@Html.T("Users.FullName")</label><input asp-for="FullName" class="form-control" /></div>
            <div class="col-md-6">
                <label asp-for="RoleId" class="form-label">@Html.T("Users.Role")</label>
                <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-select"></select>
            </div>
            <div class="col-md-6"><label asp-for="Password" class="form-label">@Html.T("Login.Password")</label><input asp-for="Password" class="form-control" /><span asp-validation-for="Password" class="text-danger small"></span></div>
            <div class="col-12 d-flex gap-2 pt-2">
                <button class="btn btn-primary">@Html.T("Users.CreateBtn")</button>
                <a class="btn btn-outline-secondary" asp-controller="Users" asp-action="Index">@Html.T("Common.Cancel")</a>
            </div>
        </form>
    </div>
</div>
