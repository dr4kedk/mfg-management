@model ChangePasswordViewModel
@{ ViewData["Title"] = Html.T("Account.ChangePasswordTitle"); }
<div class="page-header">
    <div><h2>@Html.T("Account.ChangePasswordTitle")</h2><div class="subtitle">@Html.T("Account.ChangePasswordSub")</div></div>
    <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Index">← @Html.T("Common.Back")</a>
</div>
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="ChangePassword" method="post" class="row g-3">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small col-12 mb-0"></div>
                    <div class="col-12"><label asp-for="OldPassword" class="form-label">@Html.T("Account.CurrentPassword")</label><input asp-for="OldPassword" class="form-control" /></div>
                    <div class="col-12"><label asp-for="NewPassword" class="form-label">@Html.T("Account.NewPassword")</label><input asp-for="NewPassword" class="form-control" /></div>
                    <div class="col-12"><label asp-for="ConfirmPassword" class="form-label">@Html.T("Account.ConfirmPassword")</label><input asp-for="ConfirmPassword" class="form-control" /></div>
                    <div class="col-12"><button type="submit" class="btn btn-primary w-100">@Html.T("Account.UpdatePassword")</button></div>
                </form>
            </div>
        </div>
    </div>
</div>
