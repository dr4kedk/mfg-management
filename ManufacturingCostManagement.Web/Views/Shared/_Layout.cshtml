@using System.Security.Claims
@using System.Globalization
@{
    var routeCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var routeAct = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    string NavActive(string controller, string? action = null)
    {
        if (!string.Equals(controller, routeCtrl, StringComparison.OrdinalIgnoreCase)) return "";
        if (action != null && !string.Equals(action, routeAct, StringComparison.OrdinalIgnoreCase)) return "";
        return "active";
    }
    bool ReportsActive() =>
        (routeCtrl == "Dashboard" && routeAct != "Index") ||
        (routeCtrl == "Materials" && routeAct == "LowStock");
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Html.T("App.Title")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --brand: #2563eb;
            --brand-dark: #1d4ed8;
            --bg: #f4f6fa;
            --surface: #ffffff;
            --border: #e5e7eb;
            --text: #1f2937;
            --text-muted: #6b7280;
            --data-fs: 14px;   /* uniform size for all data values in tables and card details */
        }
        html, body { height: 100%; }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: var(--bg);
            color: var(--text);
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            font-size: 14.5px;
            margin: 0;
        }
        /* Number + unit alignment helper (e.g. "38,00 pcs") */
        .num-unit {
            display: inline-flex;
            align-items: baseline;
            gap: 4px;
            font-variant-numeric: tabular-nums;
        }
        .num-unit .num  { text-align: right; min-width: 60px; }
        .num-unit .unit { text-align: left;  min-width: 32px; opacity: .75; }
        .badge.num-unit { padding-top: .3em; padding-bottom: .3em; }

        /* === All text inside data tables and detail dl rows uses one size === */
        .table tbody td,
        .table tbody td * {
            font-size: var(--data-fs);
        }
        .table tbody td small { font-size: var(--data-fs); }
        .table tbody td code { font-size: var(--data-fs); }
        .table tbody td .badge { font-size: 12px; }
        dl.row dt, dl.row dd, dl.row dd * { font-size: var(--data-fs); }

        /* === Bootstrap 5.3 color classes back-ported to 5.1 === */
        .bg-primary-subtle    { background-color: #cfe2ff !important; }
        .bg-secondary-subtle  { background-color: #e9ecef !important; }
        .bg-success-subtle    { background-color: #d1e7dd !important; }
        .bg-danger-subtle     { background-color: #f8d7da !important; }
        .bg-warning-subtle    { background-color: #fff3cd !important; }
        .bg-info-subtle       { background-color: #cff4fc !important; }
        .text-primary-emphasis   { color: #052c65 !important; }
        .text-secondary-emphasis { color: #41464b !important; }
        .text-success-emphasis   { color: #0f5132 !important; }
        .text-danger-emphasis    { color: #842029 !important; }
        .text-warning-emphasis   { color: #664d03 !important; }
        .text-info-emphasis      { color: #055160 !important; }
        .page-wrap {
            flex: 1 0 auto;
            display: flex;
            flex-direction: column;
        }
        .page-wrap > .container-fluid { flex: 1 0 auto; }
        footer.app-footer { flex-shrink: 0; }

        h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6 { letter-spacing: -.01em; font-weight: 600; }
        a { text-decoration: none; }

        /* === Navbar === */
        .navbar.app-nav {
            background: linear-gradient(180deg, #0f172a 0%, #111c36 100%);
            border-bottom: 1px solid rgba(255,255,255,.06);
            padding: .55rem 0;
            box-shadow: 0 1px 0 rgba(0,0,0,.08);
        }
        .navbar.app-nav .navbar-brand {
            font-weight: 700;
            font-size: 18px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #fff;
        }
        .navbar.app-nav .navbar-brand .brand-mark {
            width: 30px; height: 30px;
            border-radius: 8px;
            background: linear-gradient(135deg, #2563eb, #1e40af);
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 16px;
            box-shadow: 0 2px 8px rgba(37,99,235,.35);
        }
        .navbar.app-nav .nav-link {
            color: rgba(255,255,255,.7);
            padding: .45rem .85rem;
            margin: 0 2px;
            border-radius: 7px;
            font-weight: 500;
            font-size: 14px;
            transition: background .15s, color .15s;
        }
        .navbar.app-nav .nav-link:hover { color: #fff; background: rgba(255,255,255,.06); }
        .navbar.app-nav .nav-link.active {
            color: #fff;
            background: linear-gradient(135deg, var(--brand), var(--brand-dark));
            box-shadow: 0 2px 8px rgba(37,99,235,.35);
        }
        .navbar.app-nav .dropdown-menu {
            border: none;
            box-shadow: 0 12px 32px rgba(15,23,42,.16);
            border-radius: 12px;
            padding: 6px;
            margin-top: 8px;
            min-width: 240px;
            font-size: 14px;
        }
        .navbar.app-nav .dropdown-item {
            border-radius: 7px;
            padding: 9px 12px;
            font-size: 13.5px;
            color: var(--text);
            background: transparent;
            border: 0;
            width: 100%;
            text-align: left;
            transition: background .12s, color .12s;
        }
        .navbar.app-nav .dropdown-item:hover,
        .navbar.app-nav .dropdown-item:focus { background: var(--bg); color: var(--brand-dark); }
        .navbar.app-nav .dropdown-item.active-lang { background: var(--bg); color: var(--brand-dark); font-weight: 600; }
        .navbar.app-nav .dropdown-divider { margin: 6px 4px; border-top-color: var(--border); }
        .navbar.app-nav .user-menu-toggle { padding-right: 12px; }
        .navbar.app-nav .user-menu form { padding: 0; }
        .navbar.app-nav .user-menu form .dropdown-item { color: #b91c1c; }
        .navbar.app-nav .user-menu form .dropdown-item:hover { background: #fef2f2; color: #991b1b; }
        .lang-switch { color: rgba(255,255,255,.75); cursor: pointer; }
        .lang-switch:hover { color: #fff; }

        /* === Cards === */
        .card {
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 1px 2px rgba(15,23,42,.04);
            background: var(--surface);
        }
        .card-header { background: transparent; border-bottom: 1px solid var(--border); padding: 14px 20px; font-weight: 600; }
        .card-body { padding: 20px; }

        /* === Page header === */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }
        .page-header h2 { margin: 0; font-size: var(--fs-xl); }
        .page-header .subtitle { color: var(--text-muted); font-size: var(--fs-sm); margin-top: 2px; font-weight: 400; }

        /* === Tables === */
        .table { margin-bottom: 0; }
        .table thead th {
            background: #eef2f7;
            color: #0f172a;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .06em;
            border-bottom: 2px solid var(--brand);
            border-top: 1px solid var(--border);
            padding: 13px 16px;
            position: relative;
        }
        .table thead th:first-child { border-top-left-radius: 4px; }
        .table thead th:last-child { border-top-right-radius: 4px; }
        .table > :not(caption) > * > * { padding: 13px 16px; vertical-align: middle; }
        .table tbody tr { transition: background .12s; }
        .table-hover tbody tr:hover { background: #f9fafb; }
        .badge { font-weight: 500; padding: .35em .65em; border-radius: 6px; }

        /* === Forms === */
        .form-label {
            font-size: 12.5px;
            font-weight: 600;
            color: #475569;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: .03em;
        }
        .form-control, .form-select {
            padding: 10px 13px;
            border-radius: 8px;
            border: 1px solid #d1d5db;
            font-size: 14px;
            background: #fff;
            transition: border .15s, box-shadow .15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(37,99,235,.12);
        }
        .form-control[readonly] { background: #f3f4f6; color: var(--text-muted); }
        textarea.form-control { min-height: 80px; }

        /* === Buttons === */
        .btn { border-radius: 8px; font-weight: 500; padding: 8px 16px; font-size: 14px; transition: transform .1s, box-shadow .1s; }
        .btn-sm { padding: 4px 10px; font-size: 12.5px; border-radius: 6px; }
        .btn-primary { background: var(--brand); border-color: var(--brand); }
        .btn-primary:hover { background: var(--brand-dark); border-color: var(--brand-dark); }
        .btn:active { transform: translateY(1px); }

        /* === Alerts === */
        .alert { border: none; border-radius: 10px; border-left: 4px solid; padding: 12px 16px; font-size: 14px; }
        .alert-success { background: #ecfdf5; color: #065f46; border-left-color: #10b981; }
        .alert-danger  { background: #fef2f2; color: #991b1b; border-left-color: #ef4444; }

        /* === KPI === */
        .kpi-icon {
            width: 46px; height: 46px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 11px;
            font-size: 20px;
            flex-shrink: 0;
        }
        .kpi-card .card-body { min-height: 112px; }
        .cost-card .card-body { min-height: 140px; }
        .stat-label {
            font-size: 11.5px;
            text-transform: uppercase;
            letter-spacing: .06em;
            font-weight: 600;
            color: var(--text-muted);
        }

        /* === Pagination === */
        .pagination { gap: 4px; }
        .page-link { border-radius: 7px !important; border: 1px solid var(--border); color: var(--text); padding: 6px 12px; font-size: 13.5px; }
        .page-item.active .page-link { background: var(--brand); border-color: var(--brand); }

        /* === Footer === */
        footer.app-footer {
            background: #fff;
            border-top: 1px solid var(--border);
            padding: 16px 0;
            color: var(--text-muted);
            font-size: 12.5px;
        }
    </style>
</head>
<body>
    <div class="page-wrap">
        <header>
            <nav class="navbar navbar-expand-md navbar-dark app-nav">
                <div class="container-fluid px-4">
                    <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                        <span class="brand-mark">⚙</span>
                        @Html.T("App.Brand")
                    </a>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse" id="navMain">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <ul class="navbar-nav me-auto">
                                <li class="nav-item"><a class="nav-link @NavActive("Dashboard","Index")" asp-controller="Dashboard" asp-action="Index">@Html.T("Nav.Dashboard")</a></li>
                                <li class="nav-item"><a class="nav-link @NavActive("ProductionOrders")" asp-controller="ProductionOrders" asp-action="Index">@Html.T("Nav.Production")</a></li>
                                <li class="nav-item"><a class="nav-link @NavActive("Products")" asp-controller="Products" asp-action="Index">@Html.T("Nav.Products")</a></li>
                                <li class="nav-item"><a class="nav-link @NavActive("Materials","Index")" asp-controller="Materials" asp-action="Index">@Html.T("Nav.Materials")</a></li>
                                <li class="nav-item"><a class="nav-link @NavActive("Suppliers")" asp-controller="Suppliers" asp-action="Index">@Html.T("Nav.Suppliers")</a></li>
                                <li class="nav-item"><a class="nav-link @NavActive("Departments")" asp-controller="Departments" asp-action="Index">@Html.T("Nav.Departments")</a></li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle @(ReportsActive() ? "active" : "")" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">@Html.T("Nav.Reports")</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="CostBreakdown">@Html.T("Nav.ProductCostAnalysis")</a></li>
                                        <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="DepartmentCosts">@Html.T("Nav.CostByDepartment")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="Materials" asp-action="LowStock">@Html.T("Nav.LowStock")</a></li>
                                    </ul>
                                </li>
                            </ul>
                            <ul class="navbar-nav align-items-center">
                                <li class="nav-item me-1">
                                    <a class="nav-link @NavActive("Docs")" asp-controller="Docs" asp-action="Index">📘 @Html.T("Nav.Docs")</a>
                                </li>
                                <li class="nav-item dropdown me-2">
                                    <a class="nav-link dropdown-toggle lang-switch" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">
                                        🌐 @(currentCulture == "vi" ? "VI" : "EN")
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li class="px-3 py-1 small text-muted text-uppercase fw-semibold" style="font-size:11px;letter-spacing:.06em;">@Html.T("Nav.Language")</li>
                                        <li><a class="dropdown-item @(currentCulture == "en" ? "active-lang" : "")" asp-controller="Language" asp-action="Set" asp-route-culture="en" asp-route-returnUrl="@returnUrl">🇬🇧 English</a></li>
                                        <li><a class="dropdown-item @(currentCulture == "vi" ? "active-lang" : "")" asp-controller="Language" asp-action="Set" asp-route-culture="vi" asp-route-returnUrl="@returnUrl">🇻🇳 Tiếng Việt</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle user-menu-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">
                                        @User.FindFirst("FullName")?.Value <span class="badge bg-primary ms-1">@User.FindFirst(ClaimTypes.Role)?.Value</span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end user-menu">
                                        <li class="px-3 py-2 small text-muted border-bottom mb-1">
                                            @Html.T("Nav.SignedInAs")<br/>
                                            <strong class="text-dark">@User.FindFirst(ClaimTypes.Name)?.Value</strong>
                                        </li>
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">🔒 @Html.T("Nav.ChangePassword")</a></li>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li><hr class="dropdown-divider" /></li>
                                            <li class="px-3 pt-1 pb-1 small text-muted text-uppercase fw-semibold" style="font-size:11px;letter-spacing:.06em;">@Html.T("Nav.Administration")</li>
                                            <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">👥 @Html.T("Nav.UserManagement")</a></li>
                                            <li><a class="dropdown-item" asp-controller="Permissions" asp-action="Index">🔑 @Html.T("Nav.PermissionsConfig")</a></li>
                                        }
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item">↩ @Html.T("Nav.SignOut")</button>
                                            </form>
                                        </li>
                                    </ul>
                                </li>
                            </ul>
                        }
                        else
                        {
                            <ul class="navbar-nav ms-auto">
                                <li class="nav-item me-1">
                                    <a class="nav-link @NavActive("Docs")" asp-controller="Docs" asp-action="Index">📘 @Html.T("Nav.Docs")</a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle lang-switch" data-bs-toggle="dropdown" href="#">🌐 @(currentCulture == "vi" ? "VI" : "EN")</a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item @(currentCulture == "en" ? "active-lang" : "")" asp-controller="Language" asp-action="Set" asp-route-culture="en" asp-route-returnUrl="@returnUrl">🇬🇧 English</a></li>
                                        <li><a class="dropdown-item @(currentCulture == "vi" ? "active-lang" : "")" asp-controller="Language" asp-action="Set" asp-route-culture="vi" asp-route-returnUrl="@returnUrl">🇻🇳 Tiếng Việt</a></li>
                                    </ul>
                                </li>
                            </ul>
                        }
                    </div>
                </div>
            </nav>
        </header>
        <div class="container-fluid px-4 pt-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>
    <footer class="app-footer">
        <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
            <span>@Html.T("Footer.Copyright")</span>
            <span>@Html.T("App.Tagline")</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
