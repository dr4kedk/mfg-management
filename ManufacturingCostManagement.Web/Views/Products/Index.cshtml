@model PagedResult<Product>
@{ ViewData["Title"] = Html.T("Products.Title"); }
<div class="page-header">
    <div><h2>@Html.T("Products.Title")</h2><div class="subtitle">@Html.T("Products.Subtitle")</div></div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a class="btn btn-primary" asp-action="Create">@Html.T("Products.NewBtn")</a>
    }
</div>
<div class="card">
    <div class="card-header bg-white">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">@Html.T("Common.Search")</label>
                <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="@Html.T("Common.Code") / @Html.T("Common.Name")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Html.T("Products.Category")</label>
                <select name="category" class="form-select">
                    <option value="">@Html.T("Common.AllOption")</option>
                    @foreach (var cat in (IEnumerable<string>)(ViewBag.Categories ?? Enumerable.Empty<string>()))
                    {
                        if (cat == ((string?)ViewBag.Category))
                        { <option value="@cat" selected>@cat</option> }
                        else
                        { <option value="@cat">@cat</option> }
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-primary"><i class="bi bi-funnel"></i> @Html.T("Common.Filter")</button>
                <a class="btn btn-outline-secondary" asp-action="Index">@Html.T("Common.ClearFilters")</a>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>@Html.T("Common.Code")</th><th>@Html.T("Common.Name")</th><th>@Html.T("Products.Category")</th><th>@Html.T("Products.Unit")</th><th class="text-end">@Html.T("Products.SellingPrice")</th><th class="text-end pe-4">@Html.T("Common.Actions")</th></tr></thead>
            <tbody>
            @foreach (var p in Model.Items)
            {
                <tr>
                    <td><code class="text-primary">@p.Code</code></td>
                    <td class="fw-semibold">@p.Name</td>
                    <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@p.Category</span></td>
                    <td>@p.Unit</td>
                    <td class="text-end fw-semibold">@p.SellingPrice.ToString("N0")</td>
                    <td class="text-end pe-4">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@p.Id"><i class="bi bi-eye"></i> @Html.T("Products.ViewBom")</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id"><i class="bi bi-pencil-square"></i> @Html.T("Common.Edit")</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('@Html.T("Common.ConfirmDelete")')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> @Html.T("Common.Delete")</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">@Html.T("Common.NoData")</td></tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model" />
</div>
