@model PagedResult<Department>
@{ ViewData["Title"] = Html.T("Departments.Title"); }
<div class="page-header">
    <div><h2>@Html.T("Departments.Title")</h2><div class="subtitle">@Html.T("Departments.Subtitle")</div></div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a class="btn btn-primary" asp-action="Create">@Html.T("Departments.NewBtn")</a>
    }
</div>
<div class="card">
    <div class="card-header bg-white"><partial name="_SearchBar" /></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>@Html.T("Common.Code")</th><th>@Html.T("Common.Name")</th><th>@Html.T("Departments.Manager")</th><th>@Html.T("Common.Description")</th><th class="text-end pe-4">@Html.T("Common.Actions")</th></tr></thead>
            <tbody>
            @foreach (var d in Model.Items)
            {
                <tr>
                    <td><code class="text-primary">@d.Code</code></td>
                    <td class="fw-semibold">@d.Name</td>
                    <td>@d.Manager</td>
                    <td><small class="text-muted">@d.Description</small></td>
                    <td class="text-end pe-4">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@d.Id"><i class="bi bi-eye"></i> @Html.T("Common.View")</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@d.Id"><i class="bi bi-pencil-square"></i> @Html.T("Common.Edit")</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="Delete" asp-route-id="@d.Id" method="post" class="d-inline" onsubmit="return confirm('@Html.T("Common.ConfirmDelete")')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> @Html.T("Common.Delete")</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">@Html.T("Common.NoData")</td></tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model" />
</div>
