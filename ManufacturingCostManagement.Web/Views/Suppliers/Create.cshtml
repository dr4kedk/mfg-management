@model Supplier
@{ ViewData["Title"] = Html.T("Suppliers.NewTitle"); }
<div class="page-header">
    <div><h2>@Html.T("Suppliers.NewTitle")</h2><div class="subtitle">@Html.T("Suppliers.NewSub")</div></div>
    <a class="btn btn-outline-secondary" asp-action="Index">← @Html.T("Common.Back")</a>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small col-12 mb-0"></div>
            <div class="col-md-6"><label asp-for="Name" class="form-label">@Html.T("Common.Name")</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="ContactPerson" class="form-label">@Html.T("Suppliers.ContactPerson")</label><input asp-for="ContactPerson" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Phone" class="form-label">@Html.T("Suppliers.Phone")</label><input asp-for="Phone" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Email" class="form-label">@Html.T("Suppliers.Email")</label><input asp-for="Email" class="form-control" /></div>
            <div class="col-12"><label asp-for="Address" class="form-label">@Html.T("Suppliers.Address")</label><textarea asp-for="Address" class="form-control"></textarea></div>
            <div class="col-12 d-flex gap-2 pt-2">
                <button class="btn btn-primary">@Html.T("Suppliers.SaveBtn")</button>
                <a class="btn btn-outline-secondary" asp-action="Index">@Html.T("Common.Cancel")</a>
            </div>
        </form>
    </div>
</div>
