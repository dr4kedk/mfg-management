@model PagedResult<Supplier>
@{ ViewData["Title"] = Html.T("Suppliers.Title"); }

<div class="page-header">
    <div>
        <h2>@Html.T("Suppliers.Title")</h2>
        <div class="subtitle">@Html.T("Suppliers.Subtitle")</div>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a class="btn btn-primary" asp-action="Create">@Html.T("Suppliers.NewBtn")</a>
    }
</div>

<div class="card">
    <div class="card-header bg-white"><partial name="_SearchBar" /></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>@Html.T("Common.Name")</th><th>@Html.T("Suppliers.Contact")</th><th>@Html.T("Suppliers.Phone")</th><th>@Html.T("Suppliers.Email")</th><th class="text-end pe-4">@Html.T("Common.Actions")</th></tr></thead>
            <tbody>
            @foreach (var s in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@s.Name</td>
                    <td>@s.ContactPerson</td>
                    <td><small class="text-muted">@s.Phone</small></td>
                    <td><small class="text-muted">@s.Email</small></td>
                    <td class="text-end pe-4">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@s.Id"><i class="bi bi-eye"></i> @Html.T("Common.View")</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@s.Id"><i class="bi bi-pencil-square"></i> @Html.T("Common.Edit")</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('@Html.T("Common.ConfirmDelete")')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> @Html.T("Common.Delete")</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">@Html.T("Common.NoData")</td></tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model" />
</div>
