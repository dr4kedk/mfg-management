@model Supplier
@{ ViewData["Title"] = Model.Name; }
<div class="page-header">
    <div><h2>@Model.Name</h2><div class="subtitle">@Html.T("Suppliers.DetailsSub")</div></div>
    <div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil-square"></i> @Html.T("Common.Edit")</a>
        }
        <a class="btn btn-outline-secondary" asp-action="Index">← @Html.T("Common.Back")</a>
    </div>
</div>
<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">@Html.T("Suppliers.ContactPerson")</dt><dd class="col-sm-9">@Model.ContactPerson</dd>
            <dt class="col-sm-3 text-muted">@Html.T("Suppliers.Phone")</dt><dd class="col-sm-9">@Model.Phone</dd>
            <dt class="col-sm-3 text-muted">@Html.T("Suppliers.Email")</dt><dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3 text-muted">@Html.T("Suppliers.Address")</dt><dd class="col-sm-9">@Model.Address</dd>
            <dt class="col-sm-3 text-muted">@Html.T("Suppliers.Registered")</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
        </dl>
    </div>
</div>
