@model PagedResult<Material>
@{ ViewData["Title"] = Html.T("Materials.Title"); }
<div class="page-header">
    <div><h2>@Html.T("Materials.Title")</h2><div class="subtitle">@Html.T("Materials.Subtitle")</div></div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a class="btn btn-primary" asp-action="Create">@Html.T("Materials.NewBtn")</a>
    }
</div>
<div class="card">
    <div class="card-header bg-white">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">@Html.T("Common.Search")</label>
                <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="@Html.T("Common.Code") / @Html.T("Common.Name")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">@Html.T("Materials.Supplier")</label>
                <select name="supplierId" asp-items="ViewBag.Suppliers" class="form-select">
                    <option value="">@Html.T("Common.AllOption")</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Html.T("Materials.Stock")</label>
                <div class="form-check mt-2">
                    <input type="checkbox" name="lowStock" value="true" class="form-check-input" @(ViewBag.LowStock == true ? "checked" : "") />
                    <label class="form-check-label">@Html.T("Common.LowStockOnly")</label>
                </div>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary"><i class="bi bi-funnel"></i> @Html.T("Common.Filter")</button>
                <a class="btn btn-outline-secondary" asp-action="Index">@Html.T("Common.ClearFilters")</a>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>@Html.T("Common.Code")</th>
                    <th>@Html.T("Common.Name")</th>
                    <th>@Html.T("Materials.Supplier")</th>
                    <th>@Html.T("Materials.Unit")</th>
                    <th class="text-end">@Html.T("Materials.UnitCost")</th>
                    <th class="text-end">@Html.T("Materials.Stock")</th>
                    <th class="text-end">@Html.T("Materials.Reorder")</th>
                    <th class="text-end pe-4">@Html.T("Common.Actions")</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var m in Model.Items)
            {
                var low = m.StockQuantity <= m.ReorderLevel;
                <tr>
                    <td><code class="text-primary">@m.Code</code></td>
                    <td class="fw-semibold">@m.Name</td>
                    <td><small class="text-muted">@m.Supplier?.Name</small></td>
                    <td><span class="badge bg-light text-dark">@m.Unit</span></td>
                    <td class="text-end">@m.UnitCost.ToString("N0")</td>
                    <td class="text-end">
                        @if (low) { <span class="badge bg-danger-subtle text-danger">⚠ @m.StockQuantity.ToString("N2")</span> }
                        else { @m.StockQuantity.ToString("N2") }
                    </td>
                    <td class="text-end text-muted">@m.ReorderLevel.ToString("N2")</td>
                    <td class="text-end pe-4">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@m.Id"><i class="bi bi-eye"></i> @Html.T("Common.View")</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@m.Id"><i class="bi bi-pencil-square"></i> @Html.T("Common.Edit")</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="Delete" asp-route-id="@m.Id" method="post" class="d-inline" onsubmit="return confirm('@Html.T("Common.ConfirmDelete")')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> @Html.T("Common.Delete")</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">@Html.T("Common.NoData")</td></tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model" />
</div>
