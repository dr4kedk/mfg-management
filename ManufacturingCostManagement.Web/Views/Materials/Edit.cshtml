@model Material
@{ ViewData["Title"] = Html.T("Materials.EditTitle"); }
<div class="page-header">
    <div><h2>@Html.T("Materials.EditTitle")</h2><div class="subtitle">@Model.Code · @Model.Name</div></div>
    <a class="btn btn-outline-secondary" asp-action="Index">← @Html.T("Common.Back")</a>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post" class="row g-3">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small col-12 mb-0"></div>
            <div class="col-md-4"><label asp-for="Code" class="form-label">@Html.T("Common.Code")</label><input asp-for="Code" class="form-control" /></div>
            <div class="col-md-8"><label asp-for="Name" class="form-label">@Html.T("Common.Name")</label><input asp-for="Name" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Unit" class="form-label">@Html.T("Materials.Unit")</label><input asp-for="Unit" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="UnitCost" class="form-label">@Html.T("Materials.UnitCost") (VND)</label><input asp-for="UnitCost" class="form-control" type="number" step="0.01" /></div>
            <div class="col-md-3"><label asp-for="StockQuantity" class="form-label">@Html.T("Materials.StockQty")</label><input asp-for="StockQuantity" class="form-control" type="number" step="0.01" /></div>
            <div class="col-md-3"><label asp-for="ReorderLevel" class="form-label">@Html.T("Materials.ReorderLevel")</label><input asp-for="ReorderLevel" class="form-control" type="number" step="0.01" /></div>
            <div class="col-md-6">
                <label asp-for="SupplierId" class="form-label">@Html.T("Materials.Supplier")</label>
                <select asp-for="SupplierId" asp-items="ViewBag.Suppliers" class="form-select"><option value="">--</option></select>
            </div>
            <div class="col-12"><label asp-for="Description" class="form-label">@Html.T("Common.Description")</label><textarea asp-for="Description" class="form-control"></textarea></div>
            <div class="col-12 d-flex gap-2 pt-2">
                <button class="btn btn-primary">@Html.T("Common.SaveChanges")</button>
                <a class="btn btn-outline-secondary" asp-action="Index">@Html.T("Common.Cancel")</a>
            </div>
        </form>
    </div>
</div>
