@model LaborCost
@{ ViewData["Title"] = Html.T("Production.AddLabor"); }
<div class="page-header">
    <div><h2>@Html.T("Production.AddLabor")</h2><div class="subtitle">@Html.T("Production.LaborSub")</div></div>
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.ProductionOrderId">← @Html.T("Common.Back")</a>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="AddLabor" method="post" class="row g-3">
            <input type="hidden" asp-for="ProductionOrderId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small col-12 mb-0"></div>
            <div class="col-md-6">
                <label asp-for="DepartmentId" class="form-label">@Html.T("Production.Department")</label>
                <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select"><option value="">--</option></select>
            </div>
            <div class="col-md-6"><label asp-for="WorkerName" class="form-label">@Html.T("Production.WorkerName")</label><input asp-for="WorkerName" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="HoursWorked" class="form-label">@Html.T("Production.HoursWorked")</label><input asp-for="HoursWorked" class="form-control" type="number" step="0.01" /></div>
            <div class="col-md-4"><label asp-for="HourlyRate" class="form-label">@Html.T("Production.HourlyRate") (VND)</label><input asp-for="HourlyRate" class="form-control" type="number" step="0.01" /></div>
            <div class="col-md-4"><label asp-for="IncurredAt" class="form-label">@Html.T("Common.Date")</label><input asp-for="IncurredAt" class="form-control" type="date" /></div>
            <div class="col-12"><label asp-for="Description" class="form-label">@Html.T("Common.Description")</label><textarea asp-for="Description" class="form-control"></textarea></div>
            <div class="col-12 d-flex gap-2 pt-2">
                <button class="btn btn-primary">@Html.T("Production.SaveLabor")</button>
                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.ProductionOrderId">@Html.T("Common.Cancel")</a>
            </div>
        </form>
    </div>
</div>
