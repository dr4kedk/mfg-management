@model OverheadCost
@{ ViewData["Title"] = Html.T("Production.AddOverhead"); }
<div class="page-header">
    <div><h2>@Html.T("Production.AddOverhead")</h2><div class="subtitle">@Html.T("Production.OverheadSub")</div></div>
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.ProductionOrderId">← @Html.T("Common.Back")</a>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="AddOverhead" method="post" class="row g-3">
            <input type="hidden" asp-for="ProductionOrderId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small col-12 mb-0"></div>
            <div class="col-md-6">
                <label asp-for="DepartmentId" class="form-label">@Html.T("Production.Department")</label>
                <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select"><option value="">--</option></select>
            </div>
            <div class="col-md-6">
                <label asp-for="Type" class="form-label">@Html.T("Production.Type")</label>
                <select asp-for="Type" class="form-select">
                    @foreach (var v in Enum.GetValues<OverheadType>()) { <option value="@((int)v)">@v</option> }
                </select>
            </div>
            <div class="col-md-6"><label asp-for="Category" class="form-label">@Html.T("Products.Category")</label><input asp-for="Category" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Amount" class="form-label">@Html.T("Production.Amount") (VND)</label><input asp-for="Amount" class="form-control" type="number" step="0.01" /></div>
            <div class="col-md-3"><label asp-for="IncurredAt" class="form-label">@Html.T("Common.Date")</label><input asp-for="IncurredAt" class="form-control" type="date" /></div>
            <div class="col-12"><label asp-for="Description" class="form-label">@Html.T("Common.Description")</label><textarea asp-for="Description" class="form-control"></textarea></div>
            <div class="col-12 d-flex gap-2 pt-2">
                <button class="btn btn-primary">@Html.T("Production.SaveOverhead")</button>
                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.ProductionOrderId">@Html.T("Common.Cancel")</a>
            </div>
        </form>
    </div>
</div>
